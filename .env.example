# ============================================
# NexaRecruit — Environment Configuration
# ============================================
# Copy this file to .env and populate with your credentials.
# NEVER commit the .env file to version control.
# ============================================

# ─── Application ─────────────────────────────────────────
NODE_ENV=development
APP_NAME=NexaRecruit

# ─── Supabase Configuration ──────────────────────────────
# Create a free project at https://supabase.com/dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── PostgreSQL Database (Supabase-hosted) ────────────────
DATABASE_URL=postgresql://postgres:[YOUR_DB_PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# ─── Redis (Local Cache Layer) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Groq AI (LLM Provider) ──────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Internal Service URLs ────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ─── Frontend Configuration ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# ─── File Upload ──────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
