# ═══════════════════════════════════════════════
# NexaRecruit — .gitignore
# ═══════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
.eggs/

# ─── Environment & Secrets ────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
*.pem
*.key

# ─── Build Outputs ────────────────────────────
.next/
dist/
build/
out/
*.js.map

# ─── Uploads (user-generated content) ────────
uploads/
*.pdf
*.docx

# ─── IDE & Editor ─────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ─── OS Files ─────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Logs ─────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Docker Volumes ───────────────────────────
postgres_data/
redis_data/

# ─── Testing & Coverage ──────────────────────
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
.coverage
*.cover

# ─── Misc ─────────────────────────────────────
*.swp
*.swo
*~
.cache/
.temp/
.tmp/

# ─── Internal Development Notes ──────────────
_READ_ME_FIRST.txt
00_START_HERE.md
Context.md
prompt.md
QUICK_START.md
README_NEW.md
SETUP_GUIDE.md
TERMINAL_REFERENCE.md
PROJECT_SUMMARY.md
